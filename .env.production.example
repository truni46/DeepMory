# Production overrides (VPS)
# Copy to .env.production and fill in your domain
# Activated when APP_ENV=production (set in docker-compose.prod.yml)

DOMAIN=your-domain.com

# --- Frontend ---
VITE_API_URL=http://your-domain.com/api/v1
VITE_SOCKET_URL=http://your-domain.com

# --- Server ---
FRONTEND_URL=http://your-domain.com

# --- Database (overridden by docker-compose environment: block) ---
DB_HOST=db

# --- Redis (overridden by docker-compose environment: block) ---
REDIS_HOST=redis
