# =============================================================
# DEPLOYMENT NOTES
# - Dev:  VITE_API_URL=http://localhost:3000/api/v1
#         FRONTEND_URL=http://localhost:5173
# - VPS:  VITE_API_URL=http://<your-vps-ip-or-domain>/api/v1   (baked into frontend build)
#         VITE_SOCKET_URL=http://<your-vps-ip-or-domain>
#         FRONTEND_URL=http://<your-vps-ip-or-domain>          (CORS allowlist in backend)
# - DB_HOST / REDIS_HOST / QDRANT_URL / NEO4J_URL are overridden
#   to Docker service names automatically — keep localhost here.
# =============================================================

# --- Frontend (Vite — baked at build time) ---
VITE_API_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000

# --- Server ---
PORT=3000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# --- Auth ---
JWT_SECRET=change-this-to-a-secure-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database (PostgreSQL) ---
# init-db.sh auto-creates: DB_NAME (main) + DB_NAMETest (test)
USE_DATABASE=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deepmory
DB_USER=admin
DB_PASSWORD=your_db_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# --- LLM ---
# Options: ollama | openai | gemini | gemini_native | vllm
LLM_PROVIDER=ollama
LLM_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# --- Embedding ---
# Options: ollama | openai | generic
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
OPENAI_EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Knowledge Graph (Neo4j) ---
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# --- RAG ---
# Options: simple (Qdrant only) | lightrag (requires Neo4j)
RAG_PROVIDER=simple
LIGHTRAG_QUERY_MODE=hybrid
LIGHTRAG_CHUNK_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP=100
LIGHTRAG_STORAGE_DIR=./rag_storage

# --- Memory ---
CONV_SUMMARY_THRESHOLD=4000
CONV_WINDOW_SIZE=10
MEMORY_EXTRACTION_ENABLED=true
REDIS_CONV_WINDOW_TTL=3600
REDIS_SUMMARY_TTL=86400

# --- Agent System ---
AGENT_MAX_ITERATIONS=10
AGENT_WORKSPACE_DIR=./agent_workspace
AGENT_SHELL_TIMEOUT=30
TAVILY_API_KEY=tvly-...

# --- Token Quota ---
TOKEN_SESSION_LIMIT=500000
TOKEN_SESSION_DURATION=7200
TOKEN_WEEKLY_LIMIT=5000000
TOKEN_WARNING_THRESHOLD=0.9
