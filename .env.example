# VITE Environment Variables

# API Base URL (backend server)
VITE_API_URL=http://localhost:3000/api

# WebSocket URL (Socket.IO server)
VITE_SOCKET_URL=http://localhost:3000

# Backend Variables (Can be same file or server/.env)

# Server Configuration
PORT=3000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
USE_DATABASE=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_tutor_db
DB_USER=ai_tutor
DB_PASSWORD=your_password

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth
JWT_SECRET=change-this-to-a-secure-random-secret

# LLM Configuration
# Options: ollama, openai, gemini, vllm
LLM_PROVIDER=ollama
LLM_MODEL=mistral

# Provider Specifics
# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI
OPENAI_API_KEY=sk-...

# Gemini
GEMINI_API_KEY=...

# vLLM
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
